<div class="channel-knobs" role="group" aria-label="電視頻道">
	<button class="channel-knob is-active" type="button" data-channel="video" aria-pressed="true">
		<span class="knob-dial"><i></i></span><b>VIDEO</b><small>CH · 01</small>
	</button>
	<button class="channel-knob" type="button" data-channel="photo" aria-pressed="false">
		<span class="knob-dial"><i></i></span><b>PHOTO</b><small>CH · 02</small>
	</button>
	<button class="channel-knob" type="button" data-channel="notes" aria-pressed="false">
		<span class="knob-dial"><i></i></span><b>NOTES</b><small>CH · 03</small>
	</button>
</div>
