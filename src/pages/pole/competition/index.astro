---
import PoleLayout from '../../../layouts/PoleLayout.astro';
import { competitions } from '../../../data/pole/competitions';
import '../../../styles/pole-competition.css';
---

<PoleLayout title="Pole Competition | Cotty Chiang" description="Cotty Chiang 的鋼管比賽錄影收藏。">
	<main class="competition-library">
		<img class="library-room" src="/images/pole-room-scene.webp" alt="" aria-hidden="true" />
		<div class="library-shade" aria-hidden="true"></div>

		<header class="library-header">
			<a href="/pole/">← 回到 Pole 房間</a>
			<div><p>MEMORY WALL · COMPETITION TAPES</p><h1>比賽錄影帶</h1></div>
			<span>選一台電視，重新播放那一次舞台。</span>
		</header>

		<section class="television-shelf" aria-label="比賽列表">
			{competitions.map((competition, competitionIndex) => (
				<a class:list={['memory-tv', `tv-${competitionIndex + 1}`]} href={`/pole/competition/${competition.id}/`}>
					<div class="tv-antenna" aria-hidden="true"><i></i><i></i></div>
					<div class="tv-case">
						<div class="tv-preview">
							{competition.featuredPhotos.map((photo, index) => (
								<img
									src={photo.src}
									alt=""
									loading={index === 0 ? 'eager' : 'lazy'}
									style={`--index: ${index}; --count: ${competition.featuredPhotos.length};`}
								/>
							))}
							<span class="tv-scanlines"></span>
						</div>
						<div class="tv-controls" aria-hidden="true">
							<i></i><i></i><span>PLAY</span>
						</div>
					</div>
					<div class="tape-label">
						<small>ARCHIVE {`${competitionIndex + 1}`.padStart(2, '0')}</small>
						<h2>{competition.name}</h2>
						<p>{competition.date} · {competition.place}</p>
						<b>{competition.rank}{competition.medal === 'bronze' ? ' · 銅牌' : ''}</b>
					</div>
				</a>
			))}
		</section>
	</main>
</PoleLayout>
