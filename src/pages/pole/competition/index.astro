---
import { readdirSync } from 'node:fs';
import { join } from 'node:path';
import Layout from '../../../layouts/Layout.astro';

function getCompetitionPhotos(id: string) {
	const directory = join(process.cwd(), 'public', 'pole', 'competition', id);

	return readdirSync(directory)
		.filter((file) => /\.(jpe?g|png|webp|avif)$/i.test(file))
		.sort((a, b) => a.localeCompare(b, 'zh-Hant'))
		.map((file) => ({
			src: `/pole/competition/${id}/${file}`,
			alt: `${id} competition photo`,
		}));
}

const competitions = [
	{
		id: 'pso2025',
		name: 'PSO 2025',
		date: '2025.03.29',
		place: '臺灣圖書館',
		rank: '4/11',
		videoUrl: 'https://www.youtube.com/embed/I5i0YMBCo5I',
		reflection: '第一次，很有趣。',
		expenses: [
			{ category: '私人課', amount: 11200, color: '#d94f30' },
			{ category: '治裝費', amount: 5124, color: '#2f6f73' },
			{ category: '娛樂費', amount: 320, color: '#e5b742' },
			{ category: '租管', amount: 6740, color: '#6b5bbd' },
			{ category: '報名費', amount: 7666, color: '#cc6f98' },
			{ category: '維修費', amount: 5300, color: '#557a2f' },
		],
	},
	{
		id: 'pso2026',
		name: 'PSO 2026',
		date: '2026.03.07',
		place: '臺灣戲曲學院',
		rank: '3/4',
		videoUrl: 'https://www.youtube.com/embed/LUEY74s_6nA',
		reflection: '第二次，很好玩。',
		expenses: [
			{ category: '私人課', amount: 16000, color: '#d94f30' },
			{ category: '租管', amount: 11675, color: '#2f6f73' },
			{ category: '報名費', amount: 8840, color: '#6b5bbd' },
			{ category: '治裝費', amount: 3450, color: '#cc6f98' },
			{ category: '道具費', amount: 1525, color: '#e5b742' },
			{ category: '鋼管週邊', amount: 453, color: '#557a2f' },
			{ category: '交通費', amount: 230, color: '#7a6251' },
		],
	},
].map((competition) => {
	const total = competition.expenses.reduce((sum, item) => sum + item.amount, 0);
	let start = 0;
	const gradient = competition.expenses
		.map((item) => {
			const end = start + (item.amount / total) * 100;
			const stop = `${item.color} ${start.toFixed(2)}% ${end.toFixed(2)}%`;
			start = end;
			return stop;
		})
		.join(', ');
	const topExpense = [...competition.expenses].sort((a, b) => b.amount - a.amount)[0];

	return {
		...competition,
		total,
		topExpense,
		photos: getCompetitionPhotos(competition.id),
		pieStyle: `background: conic-gradient(${gradient});`,
	};
});

const formatMoney = (amount: number) => `NT$${amount.toLocaleString('zh-TW')}`;
---

<Layout title="Pole Competition | Cotty Chiang" description="Cotty Chiang 的鋼管比賽紀錄。">
	<main class="page">
		<header class="hero">
			<a class="back" href="/pole/">Pole</a>
			<p class="eyebrow">Competition</p>
			<h1>比賽紀錄</h1>
			<p>PSO 2025 與 PSO 2026 的影片、照片、基本資訊、心得和花費分析。</p>
		</header>

		{competitions.map((competition) => (
			<article class="competition" id={competition.id}>
				<header class="competition-header">
					<div>
						<p class="label">{competition.id}</p>
						<h2>{competition.name}</h2>
					</div>
					<dl class="facts">
						<div>
							<dt>時間</dt>
							<dd>{competition.date}</dd>
						</div>
						<div>
							<dt>地點</dt>
							<dd>{competition.place}</dd>
						</div>
						<div>
							<dt>名次</dt>
							<dd>{competition.rank}</dd>
						</div>
					</dl>
				</header>

				<section class="media-section" aria-labelledby={`${competition.id}-video`}>
					<h3 id={`${competition.id}-video`}>比賽影片</h3>
					<div class="video-placeholder">
						{competition.videoUrl ? (
							<iframe
								src={competition.videoUrl}
								title={`${competition.name} YouTube video`}
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
								allowfullscreen
							></iframe>
						) : (
							<p>YouTube 影片待補</p>
						)}
					</div>
				</section>

				<section class="media-section" aria-labelledby={`${competition.id}-photos`}>
					<h3 id={`${competition.id}-photos`}>比賽照片</h3>
					<div class="photo-grid">
						{competition.photos.map((photo, index) => (
							<a class="photo-link" href={photo.src} target="_blank">
								<img src={photo.src} alt={`${photo.alt} ${index + 1}`} loading="lazy" />
							</a>
						))}
					</div>
				</section>

				<section class="reflection" aria-labelledby={`${competition.id}-reflection`}>
					<h3 id={`${competition.id}-reflection`}>比賽心得</h3>
					<p>{competition.reflection}</p>
				</section>

				<section class="expenses" aria-labelledby={`${competition.id}-expenses`}>
					<div>
						<h3 id={`${competition.id}-expenses`}>花費分析</h3>
						<p>
							總花費 {formatMoney(competition.total)}，最高項目是
							<strong>{competition.topExpense.category}</strong>
							（{formatMoney(competition.topExpense.amount)}）。
						</p>
					</div>
					<div class="chart-wrap">
						<div class="pie" style={competition.pieStyle}>
							<span>{formatMoney(competition.total)}</span>
						</div>
						<ul class="legend">
							{competition.expenses.map((item) => (
								<li>
									<span style={`background: ${item.color};`}></span>
									<b>{item.category}</b>
									<em>{formatMoney(item.amount)}</em>
								</li>
							))}
						</ul>
					</div>
				</section>
			</article>
		))}
	</main>
</Layout>

<style>
	.page {
		width: min(100%, 1120px);
		margin: 0 auto;
		padding: 36px 24px 88px;
	}

	.back {
		color: #5f6258;
		font-weight: 800;
		text-decoration: none;
	}

	.hero {
		padding: 72px 0 42px;
	}

	.eyebrow,
	.label {
		color: #b5422a;
		font-weight: 850;
		text-transform: uppercase;
	}

	.hero h1 {
		margin: 0;
		font-size: clamp(3.4rem, 10vw, 7.5rem);
		line-height: 0.95;
	}

	.hero p,
	.reflection p,
	.expenses p {
		max-width: 720px;
		color: #3d3d38;
		font-size: 1.1rem;
		line-height: 1.75;
	}

	.competition {
		border-top: 2px solid #171717;
		padding: 38px 0 72px;
	}

	.competition-header {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 0.8fr);
		gap: 28px;
		align-items: start;
	}

	h2 {
		margin: 0;
		font-size: clamp(2.4rem, 6vw, 4.5rem);
		line-height: 1;
	}

	h3 {
		margin: 0 0 16px;
		font-size: 1.25rem;
	}

	.facts {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1px;
		margin: 0;
		background: #d8d1c1;
		border: 1px solid #d8d1c1;
	}

	.facts div {
		padding: 16px;
		background: #fffdf8;
	}

	dt {
		color: #68655d;
		font-size: 0.85rem;
		font-weight: 800;
	}

	dd {
		margin: 8px 0 0;
		font-size: 1rem;
		font-weight: 850;
	}

	.media-section,
	.reflection,
	.expenses {
		margin-top: 42px;
	}

	.video-placeholder {
		display: grid;
		aspect-ratio: 16 / 9;
		place-items: center;
		border: 1px solid #d8d1c1;
		background: #26251f;
		color: #fff;
	}

	iframe {
		width: 100%;
		height: 100%;
		border: 0;
	}

	.photo-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 10px;
	}

	.photo-link {
		display: block;
		aspect-ratio: 4 / 5;
		overflow: hidden;
		border: 1px solid #d8d1c1;
		background: #fffdf8;
	}

	.photo-link img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 180ms ease;
	}

	.photo-link:hover img,
	.photo-link:focus-visible img {
		transform: scale(1.03);
	}

	.expenses {
		display: grid;
		grid-template-columns: minmax(0, 0.75fr) minmax(360px, 1fr);
		gap: 28px;
		align-items: start;
	}

	.chart-wrap {
		display: grid;
		grid-template-columns: 220px minmax(0, 1fr);
		gap: 24px;
		align-items: center;
	}

	.pie {
		display: grid;
		width: 220px;
		aspect-ratio: 1;
		place-items: center;
		border-radius: 50%;
		position: relative;
	}

	.pie::after {
		position: absolute;
		width: 54%;
		aspect-ratio: 1;
		border-radius: 50%;
		background: #f7f5ef;
		content: "";
	}

	.pie span {
		position: relative;
		z-index: 1;
		font-weight: 900;
	}

	.legend {
		display: grid;
		gap: 10px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.legend li {
		display: grid;
		grid-template-columns: 14px minmax(0, 1fr) auto;
		gap: 10px;
		align-items: center;
	}

	.legend span {
		width: 14px;
		aspect-ratio: 1;
	}

	.legend em {
		color: #555149;
		font-style: normal;
		font-weight: 750;
	}

	@media (max-width: 880px) {
		.competition-header,
		.expenses,
		.chart-wrap {
			grid-template-columns: 1fr;
		}

		.photo-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.facts {
			grid-template-columns: 1fr;
		}

		.pie {
			width: min(100%, 220px);
		}
	}
</style>
