---
import PoleLayout from '../../../layouts/PoleLayout.astro';
import RetroTelevision from '../../../components/pole/competition/RetroTelevision.astro';
import SceneDecorations from '../../../components/pole/competition/SceneDecorations.astro';
import { competitions as competitionData } from '../../../data/pole/competitions';
import '../../../styles/pole-competition-tv.css';

export function getStaticPaths() {
	return competitionData.map((competition) => ({ params: { id: competition.id }, props: { competition } }));
}

const { competition } = Astro.props;
const total = competition.expenses.reduce((sum, item) => sum + item.amount, 0);
const formatMoney = (amount: number) => `NT$${amount.toLocaleString('zh-TW')}`;
---

<PoleLayout title={`${competition.name} | Pole Competition`} description={`${competition.name} 的電視比賽紀錄。`}>
	<main class="competition-tv-scene" data-competition-scene>
		<img class="tv-room-backdrop" src="/images/pole-room-scene.webp" alt="" aria-hidden="true" />
		<div class="tv-room-light" aria-hidden="true"></div>
		<SceneDecorations competition={competition} />

		<header class="tv-scene-header">
			<div class="on-air"><i></i><span>MEMORY PLAYBACK</span></div>
			<div class="scene-title"><small>{competition.id.toUpperCase()} · MASTER TAPE</small><h1>{competition.name}</h1></div>
			<dl>
				<div><dt>DATE</dt><dd>{competition.date}</dd></div>
				<div><dt>PLACE</dt><dd>{competition.place}</dd></div>
				<div><dt>RANK</dt><dd>{competition.rank}</dd></div>
			</dl>
		</header>

		<section class="tv-corner" aria-label={`${competition.name} 復古電視播放場景`}>
			<RetroTelevision competition={competition} total={total} formatMoney={formatMoney} />
		</section>
	</main>
</PoleLayout>
