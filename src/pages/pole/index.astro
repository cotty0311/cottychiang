---
import Layout from '../../layouts/Layout.astro';
import { readCsv } from '../../lib/csv';
import practiceRecordsCsv from '../../data/pole/practice_records.csv?raw';

const links = [
	{
		href: '/pole/competition/',
		label: 'Competition',
		description: '比賽影片、照片、資訊、心得與花費分析。',
	},
	{
		href: '/pole/practice/',
		label: 'Practice',
		description: '依季、月、週折疊的日常練習紀錄。',
	},
	{
		href: '/pole/dictionary/',
		label: 'Dictionary',
		description: '鋼管動作字典預留區。',
	},
	{
		href: '/pole/event/',
		label: 'Event',
		description: '營隊與活動紀錄預留區。',
	},
];

const practiceEvents = readCsv(practiceRecordsCsv).map((record) => ({
	type: 'practice',
	date: record.date,
	title: record.title || '練習紀錄',
	meta: [record.location, record.duration ? `${record.duration} hr` : ''].filter(Boolean).join(' · '),
	href: `/pole/practice/#practice-${record.date}`,
}));

const calendarEvents = [
	{
		type: 'competition',
		date: '2025-03-29',
		title: 'PSO 2025',
		meta: '臺灣圖書館 · 4/11',
		href: '/pole/competition/#pso2025',
	},
	{
		type: 'competition',
		date: '2026-03-07',
		title: 'PSO 2026',
		meta: '臺灣戲曲學院 · 3/4',
		href: '/pole/competition/#pso2026',
	},
	{
		type: 'event',
		date: '2025-07-02',
		endDate: '2025-07-05',
		title: 'Dazzling pole camp',
		meta: '2025.07.02 - 2025.07.05',
		href: '/pole/event/#dazzling-pole-camp',
	},
	...practiceEvents,
].sort((a, b) => b.date.localeCompare(a.date));

const monthFormatter = new Intl.DateTimeFormat('zh-TW', {
	year: 'numeric',
	month: 'long',
});

const dateFormatter = new Intl.DateTimeFormat('zh-TW', {
	month: '2-digit',
	day: '2-digit',
	weekday: 'short',
});

const typeLabels = {
	competition: 'Competition',
	practice: 'Practice',
	event: 'Event',
};

const monthGroups = [...calendarEvents.reduce((groups, event) => {
	const month = event.date.slice(0, 7);
	groups.set(month, [...(groups.get(month) ?? []), event]);
	return groups;
}, new Map<string, typeof calendarEvents>()).entries()].sort(([a], [b]) => b.localeCompare(a));

function formatDate(date: string) {
	return dateFormatter.format(new Date(`${date}T00:00:00`));
}

function formatMonth(month: string) {
	return monthFormatter.format(new Date(`${month}-01T00:00:00`));
}
---

<Layout title="Pole | Cotty Chiang" description="Cotty Chiang 的鋼管紀錄。">
	<main class="pole-home">
		<header>
			<a class="back" href="/">Cotty Chiang</a>
			<p class="eyebrow">Pole archive</p>
			<h1>Pole</h1>
			<p>比賽、練習、動作與活動紀錄。先把資料架好，之後就能慢慢補照片和影片。</p>
		</header>

		<nav class="grid" aria-label="Pole sections">
			{links.map((link) => (
				<a href={link.href}>
					<span>{link.label}</span>
					<small>{link.description}</small>
				</a>
			))}
		</nav>

		<section class="calendar" aria-labelledby="calendar-title">
			<div class="section-heading">
				<p class="eyebrow">Calendar</p>
				<h2 id="calendar-title">日期檢視</h2>
			</div>

			<div class="legend" aria-label="Event types">
				<span class="competition">Competition</span>
				<span class="practice">Practice</span>
				<span class="event">Event</span>
			</div>

			<div class="months">
				{monthGroups.map(([month, events]) => (
					<section class="month">
						<h3>{formatMonth(month)}</h3>
						<div class="event-list">
							{events.map((event) => (
								<a class={`calendar-item ${event.type}`} href={event.href}>
									<time datetime={event.date}>
										{formatDate(event.date)}
										{event.endDate ? ` - ${formatDate(event.endDate)}` : ''}
									</time>
									<span>{event.title}</span>
									<small>{typeLabels[event.type]}{event.meta ? ` · ${event.meta}` : ''}</small>
								</a>
							))}
						</div>
					</section>
				))}
			</div>
		</section>
	</main>
</Layout>

<style>
	.pole-home {
		width: min(100%, 1040px);
		margin: 0 auto;
		padding: 36px 24px 72px;
	}

	header {
		padding: 88px 0 44px;
	}

	.back {
		color: #5f6258;
		font-weight: 700;
		text-decoration: none;
	}

	.eyebrow {
		margin: 56px 0 14px;
		color: #b5422a;
		font-weight: 800;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		font-size: clamp(4rem, 12vw, 9rem);
		line-height: 0.9;
	}

	p {
		max-width: 680px;
		color: #3d3d38;
		font-size: 1.2rem;
		line-height: 1.7;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
	}

	.grid a {
		border: 1px solid #d8d1c1;
		padding: 22px;
		background: #fffdf8;
		color: #171717;
		text-decoration: none;
	}

	.grid span {
		display: block;
		font-size: 1.35rem;
		font-weight: 850;
	}

	.grid small {
		display: block;
		margin-top: 12px;
		color: #656258;
		font-size: 0.98rem;
		line-height: 1.6;
	}

	.grid a:hover,
	.grid a:focus-visible {
		border-color: #171717;
	}

	.calendar {
		margin-top: 56px;
	}

	.section-heading {
		display: flex;
		gap: 20px;
		align-items: end;
		justify-content: space-between;
		border-top: 2px solid #171717;
		padding-top: 28px;
	}

	h2 {
		margin: 0;
		font-size: clamp(2rem, 5vw, 4rem);
		line-height: 1;
	}

	.legend {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin: 24px 0;
	}

	.legend span {
		border: 1px solid #171717;
		padding: 7px 10px;
		font-size: 0.78rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.months {
		display: grid;
		gap: 18px;
	}

	.month {
		display: grid;
		grid-template-columns: 180px minmax(0, 1fr);
		gap: 16px;
		border: 1px solid #d8d1c1;
		background: #fffdf8;
		padding: 16px;
	}

	h3 {
		position: sticky;
		top: 16px;
		align-self: start;
		margin: 0;
		font-size: 1.15rem;
	}

	.event-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 10px;
	}

	.calendar-item {
		display: grid;
		gap: 7px;
		border-left: 6px solid #171717;
		padding: 13px 14px;
		background: #f7f5ef;
		color: #171717;
		text-decoration: none;
	}

	.calendar-item time {
		color: #5f6258;
		font-size: 0.82rem;
		font-weight: 850;
	}

	.calendar-item span {
		font-weight: 900;
		line-height: 1.35;
	}

	.calendar-item small {
		color: #656258;
		font-size: 0.86rem;
		line-height: 1.45;
	}

	.calendar-item.competition,
	.legend .competition {
		border-color: #d94f30;
	}

	.calendar-item.practice,
	.legend .practice {
		border-color: #2f6f73;
	}

	.calendar-item.event,
	.legend .event {
		border-color: #6b5bbd;
	}

	.calendar-item:hover,
	.calendar-item:focus-visible {
		background: #fff;
		outline: 2px solid #171717;
		outline-offset: 0;
	}

	@media (max-width: 720px) {
		.grid {
			grid-template-columns: 1fr;
		}

		.month,
		.event-list {
			grid-template-columns: 1fr;
		}
	}
</style>
