---
import PoleLayout from '../../../layouts/PoleLayout.astro';
---

<PoleLayout title="Pole Dictionary | Cotty Chiang" description="Cotty Chiang 的鋼管動作字典預留頁。">
	<main class="pole-page">
		<div class="pole-topbar">
			<a class="pole-back" href="/pole/">Pole Universe</a>
			<nav class="pole-nav" aria-label="Pole navigation">
				<a href="/pole/practice/">Practice</a>
				<a href="/pole/competition/">Competition</a>
				<a href="/pole/event/">Event</a>
			</nav>
		</div>
		<section class="dictionary-stage">
			<p class="eyebrow">Dictionary</p>
			<h1 class="page-title gradient-word">動作字典</h1>
			<p class="dictionary-copy">一顆仍在聚合的知識星體。之後會收錄動作、進出法、肌群提示與影片筆記。</p>
			<div class="dictionary-orb" aria-hidden="true"></div>
		</section>
	</main>
</PoleLayout>
