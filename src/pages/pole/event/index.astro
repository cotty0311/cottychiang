---
import PoleLayout from '../../../layouts/PoleLayout.astro';
---

<PoleLayout title="Pole Event | Cotty Chiang" description="Cotty Chiang 的鋼管活動紀錄。">
	<main class="pole-page">
		<div class="pole-topbar">
			<a class="pole-back" href="/pole/">Pole Universe</a>
			<nav class="pole-nav" aria-label="Pole navigation">
				<a href="/pole/practice/">Practice</a>
				<a href="/pole/competition/">Competition</a>
				<a href="/pole/dictionary/">Dictionary</a>
			</nav>
		</div>
		<header class="pole-hero compact">
			<p class="eyebrow">Event</p>
			<h1 class="gradient-word">活動紀錄</h1>
			<p class="hero-copy">有些軌道只交會幾天，卻會留下很久的光。</p>
		</header>

		<article class="event-card glass-panel" id="dazzling-pole-camp">
			<p class="date">2025.07.02 - 2025.07.05</p>
			<h2>Dazzling pole camp</h2>
			<p>營隊紀錄預留位置。之後可以補課程照片、學到的技巧、老師筆記和心得。</p>
		</article>
	</main>
</PoleLayout>
