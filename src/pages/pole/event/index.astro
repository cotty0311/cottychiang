---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Pole Event | Cotty Chiang" description="Cotty Chiang 的鋼管活動紀錄。">
	<main class="page">
		<header>
			<a class="back" href="/pole/">Pole</a>
			<p class="eyebrow">Event</p>
			<h1>活動紀錄</h1>
		</header>

		<article class="event-card" id="dazzling-pole-camp">
			<p class="date">2025.07.02 - 2025.07.05</p>
			<h2>Dazzling pole camp</h2>
			<p>營隊紀錄預留位置。之後可以補課程照片、學到的技巧、老師筆記和心得。</p>
		</article>
	</main>
</Layout>

<style>
	.page {
		width: min(100%, 960px);
		margin: 0 auto;
		padding: 36px 24px 88px;
	}

	header {
		padding: 72px 0 42px;
	}

	.back {
		color: #5f6258;
		font-weight: 800;
		text-decoration: none;
	}

	.eyebrow,
	.date {
		color: #b5422a;
		font-weight: 850;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		font-size: clamp(3.4rem, 10vw, 7.5rem);
		line-height: 0.95;
	}

	.event-card {
		border: 1px solid #d8d1c1;
		padding: 26px;
		background: #fffdf8;
	}

	h2 {
		margin: 0;
		font-size: clamp(2rem, 5vw, 4rem);
		line-height: 1;
	}

	p {
		max-width: 640px;
		color: #3d3d38;
		font-size: 1.1rem;
		line-height: 1.75;
	}
</style>
