---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Cotty Chiang"
	description="Cotty Chiang 的個人網站。"
>
	<main class="home">
		<section class="intro" aria-label="Cotty Chiang personal homepage">
			<p class="eyebrow">cottychiang.com</p>
			<h1>Cotty Chiang</h1>
			<p class="lead">
				嗨，我是 Cotty。這裡會慢慢整理我的作品、想法，以及正在做的事。
			</p>
			<div class="actions" aria-label="Links">
				<a href="/pole/">Pole</a>
				<a href="mailto:hello@cottychiang.com">Email</a>
				<a href="https://github.com/cotty0311" target="_blank" rel="noreferrer">GitHub</a>
			</div>
		</section>
	</main>
</Layout>

<style>
	.home {
		display: grid;
		min-height: 100svh;
		place-items: center;
		padding: 32px;
	}

	.intro {
		width: min(100%, 720px);
	}

	.eyebrow {
		margin: 0 0 18px;
		color: #5a5a52;
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		font-size: clamp(3.25rem, 12vw, 8rem);
		line-height: 0.92;
		letter-spacing: 0;
	}

	.lead {
		max-width: 560px;
		margin: 28px 0 0;
		color: #3d3d38;
		font-size: clamp(1.2rem, 2.8vw, 1.65rem);
		line-height: 1.65;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 34px;
	}

	.actions a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		border: 1px solid #25251f;
		padding: 0 18px;
		background: #171717;
		color: #fff;
		font-weight: 700;
		text-decoration: none;
		transition:
			background 160ms ease,
			color 160ms ease;
	}

	.actions a + a {
		background: transparent;
		color: #171717;
	}

	.actions a:hover,
	.actions a:focus-visible {
		background: #d94f30;
		color: #fff;
	}

	@media (max-width: 520px) {
		.home {
			place-items: end start;
			padding: 24px;
		}

		.actions {
			width: 100%;
		}

		.actions a {
			flex: 1 1 150px;
		}
	}
</style>
